<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd"
        logicalFilePath="changelog-6.6.9">

    <changeSet author="author" id="changelog-6.6.9-create-feature">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="tc_feature"/>
            </not>
        </preConditions>

        <createTable tableName="tc_feature">
            <column autoIncrement="true" name="id" type="INT">
                <constraints primaryKey="true" />
            </column>
            <column name="feature" type="VARCHAR(128)">
                <constraints nullable="false" />
            </column>
            <column name="details" type="VARCHAR(1024)">
                <constraints nullable="true" />
            </column>
            <column name="versionNo" type="DOUBLE" defaultValueNumeric="0">
                <constraints nullable="false" />
            </column>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false" />
            </column>
        </createTable>

    </changeSet>

    <changeSet author="author" id="changelog-6.6.9-create-user-feature">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="tc_user_feature"/>
            </not>
        </preConditions>

        <createTable tableName="tc_user_feature">
            <column name="userid" type="INT">
                <constraints nullable="false" />
            </column>
            <column name="featureid" type="INT">
                <constraints nullable="false" />
            </column>
        </createTable>

        <createIndex tableName="tc_user_feature" indexName="idx_user_feature_userid">
            <column name="userid" />
        </createIndex>

    </changeSet>

</databaseChangeLog>
